diff --git a/openbox/client.h b/openbox/client.h
index 11a01400..a69c25ec 100644
--- openbox/client.h
+++ openbox/client.h
@@ -268,6 +268,10 @@ struct _ObClient
     gboolean max_vert;
     /*! The window is maximized to fill the screen horizontally */
     gboolean max_horz;
+    gboolean snapped_top; /*! The window is snapped to fill at most the top half of the screen **MAY COMBINE WITH TWO OTHER SNAPS TO FORM A CORNER SNAP** */
+    gboolean snapped_left; /*! The window is snapped to fill at most the left half of the screen */
+    gboolean snapped_bottom; /*! The window is snapped to fill at most the bottom half of the screen */
+    gboolean snapped_right; /*! The window is snapped to fill at most the right half of the screen */
     /*! The window should not be displayed by pagers */
