diff --git a/openbox/moveresize.c b/openbox/moveresize.c
index d12a64de..bed912c5 100644
--- openbox/moveresize.c
+++ openbox/moveresize.c
@@ -372,7 +372,7 @@ void moveresize_end(gboolean cancel)
 
 static void do_move(gboolean keyboard, gint keydist)
 {
-    gint resist;
+    gint resist, x, y;
 
     if (keyboard) resist = keydist - 1; /* resist for one key press */
     else resist = config_resist_win;
@@ -380,6 +380,71 @@ static void do_move(gboolean keyboard, gint keydist)
     if (!keyboard) resist = config_resist_edge;
     resist_move_monitors(moveresize_client, resist, &cur_x, &cur_y);
 
+   screen_pointer_pos(&x, &y);
+
+   const Rect *a = screen_physical_area_active();
+   gint height = RECT_BOTTOM(*a) - RECT_TOP(*a);
+   gint width = RECT_RIGHT(*a) - RECT_LEFT(*a);
+
+   if (y == 0 || x == 0 || x == width || y == height) {
+	if ((y == 0 && !moveresize_client->snapped_top && x != 0 && x != width) 
+		|| (y == height && !moveresize_client->snapped_bottom && x != 0 && x != width) 
+		|| (x == 0 && !moveresize_client->snapped_left && y != 0 && y != height) 
+		|| (x == width && !moveresize_client->snapped_left && y != 0 && y != height)) {
+			moveresize_client->pre_max_area.x = cur_x;
+			moveresize_client->pre_max_area.y = cur_y;
+			moveresize_client->pre_max_area.width = cur_w;
+			moveresize_client->pre_max_area.height = cur_h;
+	}
+   }
+   else if (moveresize_client->snapped_top
+		|| moveresize_client->snapped_bottom
+		|| moveresize_client->snapped_left
+		|| moveresize_client->snapped_right) {
+	cur_x = moveresize_client->pre_max_area.x;
+	cur_y = moveresize_client->pre_max_area.y;
+	cur_w = moveresize_client->pre_max_area.width;
+	cur_h = moveresize_client->pre_max_area.height;
+   }
+	moveresize_client->snapped_top = (y==0);
+	moveresize_client->snapped_left = (x==0);
+	moveresize_client->snapped_right = (x==width);
+	moveresize_client->snapped_bottom = (y==height);
+	if (moveresize_client->snapped_top || moveresize_client->snapped_bottom || moveresize_client->snapped_left || moveresize_client->snapped_right) {
+		cur_x = (moveresize_client->snapped_right) ? width / 2 : 0;
+		cur_y = (moveresize_client->snapped_bottom) ? height / 2 : 0;
+		cur_w = (moveresize_client->snapped_left || moveresize_client->snapped_right) ? width / 2 : width;
+		cur_h = (moveresize_client->snapped_top || moveresize_client->snapped_bottom) ? height / 2 : height;	
+	}
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
     client_configure(moveresize_client, cur_x, cur_y, cur_w, cur_h,
                      TRUE, FALSE, FALSE);
     if (config_resize_popup_show == 2) /* == "Always" */
